{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact form submission from a potential client.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The full name of the person inquiring." },
        "email": { "type": "string", "format": "email", "description": "The contact email address." },
        "phone": { "type": "string", "description": "The contact phone number." },
        "service": { "type": "string", "description": "The service they are interested in." },
        "message": { "type": "string", "description": "The detailed project requirements or message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the inquiry was submitted." }
      },
      "required": ["name", "email", "phone", "message", "createdAt"]
    }
  },
  "firestore": {
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of business inquiries."
    }
  }
}
